# OpenAI-compatible endpoint
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=

# Optional Claude vision review provider
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
SIE_AUTOPPT_CLAUDE_MODEL=claude-3-7-sonnet-latest

# Core generation behavior
SIE_AUTOPPT_LLM_MODEL=gpt-4o-mini
SIE_AUTOPPT_LLM_TIMEOUT_SEC=90
SIE_AUTOPPT_LLM_API_STYLE=responses
SIE_AUTOPPT_LLM_REASONING_EFFORT=low
SIE_AUTOPPT_LLM_VERBOSITY=low

# Local behavior toggles
SIE_AUTOPPT_OUTPUT_DIR=
SIE_AUTOPPT_DISABLE_LOCAL_AI_DISCOVERY=0
